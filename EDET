{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":15650320,"datasetId":10019202,"databundleVersionId":16586235}],"dockerImageVersionId":31329,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# This Python 3 environment comes with many helpful analytics libraries installed\n# It is defined by the kaggle/python Docker image: https://github.com/kaggle/docker-python\n# For example, here's several helpful packages to load\n\nimport numpy as np # linear algebra\nimport pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)\n\n# Input data files are available in the read-only \"../input/\" directory\n# For example, running this (by clicking run or pressing Shift+Enter) will list all files under the input directory\n\nimport os\nfor dirname, _, filenames in os.walk('/kaggle/input'):\n    for filename in filenames:\n        print(os.path.join(dirname, filename))\n\n# You can write up to 20GB to the current directory (/kaggle/working/) that gets preserved as output when you create a version using \"Save & Run All\" \n# You can also write temporary files to /kaggle/temp/, but they won't be saved outside of the current session","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# 1. Install dependencies\n!pip install effdet timm pycocotools\n\nimport torch\nfrom torch.utils.data import Dataset, DataLoader\nfrom PIL import Image\nimport json, os, time\nimport torchvision.transforms as T\nimport effdet\nfrom effdet import create_model\n\n# 2. Kaggle File Paths\nDATASET_DIR = \"/kaggle/input/datasets/randycalunodjr/hand-project/Hand_Project_v2\"\nTRAIN_ANN   = f\"{DATASET_DIR}/train/_annotations.coco.json\"\nVALID_ANN   = f\"{DATASET_DIR}/valid/_annotations.coco.json\"\nTRAIN_IMG   = f\"{DATASET_DIR}/train\"\nVALID_IMG   = f\"{DATASET_DIR}/valid\"\n\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\nprint(\"Using:\", device)\n\n# 3. The FIXED Dataset Class\nclass CocoHandDataset(Dataset):\n    def __init__(self, img_dir, ann_file, img_size=256):\n        with open(ann_file) as f:\n            self.coco = json.load(f)\n\n        self.img_dir = img_dir\n        self.img_size = img_size\n        self.images = self.coco['images']\n\n        used_ids = sorted(set(ann['category_id'] for ann in self.coco['annotations']))\n        self.cat_remap = {old_id: new_id for new_id, old_id in enumerate(used_ids, start=1)}\n\n        self.img_id_to_anns = {}\n        for ann in self.coco['annotations']:\n            iid = ann['image_id']\n            self.img_id_to_anns.setdefault(iid, []).append(ann)\n\n        self.transform = T.Compose([\n            T.Resize((img_size, img_size)),\n            T.ToTensor(),\n            T.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\n        ])\n\n    def __len__(self):\n        return len(self.images)\n\n    def __getitem__(self, idx):\n        img_info = self.images[idx]\n        img_path = os.path.join(self.img_dir, img_info['file_name'])\n        img = Image.open(img_path).convert('RGB')\n        w, h = img.size\n\n        anns = self.img_id_to_anns.get(img_info['id'], [])\n        boxes, labels = [], []\n        \n        scale_x = self.img_size / w\n        scale_y = self.img_size / h\n\n        for ann in anns:\n            x, y, bw, bh = ann['bbox']\n            # Absolute pixel coordinates\n            x_min = x * scale_x\n            y_min = y * scale_y\n            x_max = (x + bw) * scale_x\n            y_max = (y + bh) * scale_y\n            \n            boxes.append([x_min, y_min, x_max, y_max])\n            labels.append(self.cat_remap[ann['category_id']])\n\n        img_tensor = self.transform(img)\n        boxes  = torch.tensor(boxes,  dtype=torch.float32) if boxes  else torch.zeros((0,4))\n        labels = torch.tensor(labels, dtype=torch.int64)   if labels else torch.zeros((0,), dtype=torch.int64)\n\n        return img_tensor, {'boxes': boxes, 'labels': labels}\n\n# 4. Data Loaders\ntrain_ds = CocoHandDataset(TRAIN_IMG, TRAIN_ANN)\nvalid_ds = CocoHandDataset(VALID_IMG, VALID_ANN)\n\ntrain_loader = DataLoader(train_ds, batch_size=8, shuffle=True,  collate_fn=lambda x: tuple(zip(*x)))\nvalid_loader = DataLoader(valid_ds, batch_size=8, shuffle=False, collate_fn=lambda x: tuple(zip(*x)))\n\n# 5. Load Model\nmodel = create_model(\n    'tf_efficientdet_d0',\n    pretrained=True,\n    num_classes=2,\n    image_size=(256, 256),\n    bench_task='train',\n    bench_labeler=True\n)\nmodel = model.to(device)\n\noptimizer = torch.optim.AdamW(model.parameters(), lr=1e-4, weight_decay=1e-4)\nscheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=50)\n\n# 6. Training Loop\nprint(\"Starting Detailed Training with corrected boxes and scales...\")\nfor epoch in range(50):\n    start_time = time.time()\n    \n    # --- TRAINING PHASE ---\n    model.train()\n    total_train_loss = 0\n\n    for imgs, targets in train_loader:\n        imgs = torch.stack(imgs).to(device)\n        \n        # FIX: We added img_scale and img_size here!\n        tgts = {\n            'bbox': [t['boxes'].to(device) for t in targets],\n            'cls':  [t['labels'].float().to(device) for t in targets],\n            'img_scale': torch.ones(len(targets)).to(device),\n            'img_size': torch.tensor([[256, 256]] * len(targets)).to(device)\n        }\n\n        optimizer.zero_grad()\n        loss = model(imgs, tgts)\n        loss = loss['loss'] if isinstance(loss, dict) else loss\n        loss.backward()\n        optimizer.step()\n        total_train_loss += loss.item()\n        \n    avg_train_loss = total_train_loss / len(train_loader)\n\n    # --- VALIDATION PHASE ---\n    model.eval()\n    total_val_loss = 0\n    \n    with torch.no_grad():\n        for val_imgs, val_targets in valid_loader:\n            val_imgs = torch.stack(val_imgs).to(device)\n            \n            # FIX: We added img_scale and img_size here too!\n            val_tgts = {\n                'bbox': [t['boxes'].to(device) for t in val_targets],\n                'cls':  [t['labels'].float().to(device) for t in val_targets],\n                'img_scale': torch.ones(len(val_targets)).to(device),\n                'img_size': torch.tensor([[256, 256]] * len(val_targets)).to(device)\n            }\n            \n            v_loss = model(val_imgs, val_tgts)\n            v_loss = v_loss['loss'] if isinstance(v_loss, dict) else v_loss\n            total_val_loss += v_loss.item()\n            \n    avg_val_loss = total_val_loss / len(valid_loader)\n    \n    scheduler.step()\n    epoch_time = time.time() - start_time \n    \n    print(f\"Epoch {epoch+1}/50 | Time: {epoch_time:.1f}s | Train Loss: {avg_train_loss:.4f} | Valid Loss: {avg_val_loss:.4f}\")\n\n# 7. Save it to Kaggle's working directory\ntorch.save(model.state_dict(), '/kaggle/working/efficientdet_best.pth')\nprint(\"Training done and model saved to /kaggle/working/!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T08:45:30.194010Z","iopub.execute_input":"2026-04-11T08:45:30.194529Z","iopub.status.idle":"2026-04-11T08:55:53.234765Z","shell.execute_reply.started":"2026-04-11T08:45:30.194485Z","shell.execute_reply":"2026-04-11T08:55:53.233695Z"}},"outputs":[{"name":"stdout","text":"Collecting effdet\n  Downloading effdet-0.4.1-py3-none-any.whl.metadata (33 kB)\nRequirement already satisfied: timm in /usr/local/lib/python3.12/dist-packages (1.0.25)\nRequirement a